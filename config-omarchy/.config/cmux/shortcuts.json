{
  "bindings": {
    "workspace.close": {
      "key": "W",
      "ctrl": true,
      "shift": true,
      "alt": false
    },
    "workspace.latest_unread": {
      "key": "U",
      "ctrl": true,
      "shift": true,
      "alt": false
    },
    "pane.split_horizontal": {
      "key": "D",
      "ctrl": true,
      "shift": true,
      "alt": false
    },
    "workspace.move_up": {
      "key": "Page_Up",
      "ctrl": true,
      "shift": true,
      "alt": false
    },
    "pane.close": {
      "key": "Q",
      "ctrl": true,
      "shift": true,
      "alt": false
    },
    "settings": {
      "key": "comma",
      "ctrl": true,
      "shift": false,
      "alt": false
    },
    "find": {
      "key": "f",
      "ctrl": true,
      "shift": false,
      "alt": false
