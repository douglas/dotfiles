plugin:hyprtasking:labels:enabled = 1
plugin:hyprtasking:labels:mode = outlined
plugin:hyprtasking:labels:grid:mode = outlined
plugin:hyprtasking:labels:linear:mode = outlined

# Non-selected labels follow Omarchy accent; selected labels inherit Omarchy accent; selection is highlighted via same-color glow.
plugin:hyprtasking:labels:text_color = 0xFF{{ accent_strip }}
plugin:hyprtasking:labels:selected_text_color = -1

# Keep a consistent size across labels; emphasize selection via color only.
plugin:hyprtasking:labels:point_size = 30
plugin:hyprtasking:labels:selected_emphasis = 1
plugin:hyprtasking:labels:selected_scale = 1.06
plugin:hyprtasking:labels:selected_glow = 1
plugin:hyprtasking:labels:selected_glow_color = -1
plugin:hyprtasking:labels:selected_glow_strength = 0.42
plugin:hyprtasking:labels:selected_glow_spread = 1.7
plugin:hyprtasking:labels:outline_width = 0.85
plugin:hyprtasking:labels:shadow_color = 0xAA000000
plugin:hyprtasking:labels:shadow_offset_x = 1.2
plugin:hyprtasking:labels:shadow_offset_y = 1.2
plugin:hyprtasking:labels:position = top_right
plugin:hyprtasking:labels:margin = 14
